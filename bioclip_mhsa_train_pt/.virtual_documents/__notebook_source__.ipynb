import torch
import torch.nn as nn
import open_clip
import pandas as pd
import os
from pathlib import Path
from sklearn.preprocessing import LabelEncoder


def get_meta_df():
    meta_fp = Path("/kaggle") / "input" / "datasets"/"elliotmonde"/"cv-animal-reid"/"data"/"unprocessed"/"metadata.csv"
    df = pd.read_csv(str(meta_fp))
    return df


def num_identities_training():
    df = get_meta_df()
    count: int = df[df["split"] == "train"]["identity"].nunique()
    return count


class BioCLIPReID(nn.Module):
    def __init__(self, num_heads=8):
        super().__init__()
        model, _, _ = open_clip.create_model_and_transforms(
            "hf-hub:imageomics/bioclip"
        )
        self.backbone = model.visual
        self.extracted_patches = None
        getattr(self.backbone, "transformer").register_forward_hook(self._hook_fn)
        self.embed_dim = 768

        # Bottleneck layer in ReID
        self.bottleneck = nn.BatchNorm1d(self.embed_dim)
        self.bottleneck.bias.requires_grad_(False)

        # MHSA Neck: Let's model attend to unique spots/scales
        self.mhsa = nn.MultiheadAttention(
            embed_dim=self.embed_dim, num_heads=num_heads, batch_first=True
        )

        # Pooling layer to get a single vector
        self.global_pool = nn.AdaptiveAvgPool1d(1)

        # ArcFace Header (only used during training)
        self.num_identities = num_identities_training()
        self.head = nn.Linear(self.embed_dim, self.num_identities, bias=False)

    def _hook_fn(self, module, input, output):
        self.extracted_patches = output

    def forward(self, x):
        # forward_features gives [Batch, 1 CLS + 196 Spatial patches, 768]
        # trigger the hook
        _ = self.backbone(x)

        patches = self.extracted_patches  # [Batch, 197, 768]

        # MHSA
        attn_output, _ = self.mhsa(patches, patches, patches)

        # Pooling to get a 768-d vector
        # [Batch, 197, 768] -> [Batch, 768, 197] -> [Batch, 768]
        embedding = self.global_pool(attn_output.transpose(1, 2)).squeeze(-1)

        # Normalize for ReID
        normalized_feat = self.bottleneck(embedding)

        if self.training:
            return self.head(normalized_feat)  # Returns class logits for loss
        else:
            return normalized_feat  # Returns the fingerprint for kaggle


def get_label_encoder():
    le = LabelEncoder()
    df = get_meta_df()
    train_df = df[df["split"] == "train"].copy()
    train_df["label"] = le.fit_transform(train_df["identity"])

    # save encoder
    import joblib

    joblib.dump(le, "identity_encoder.pkl")


from torch.utils.data import Dataset, DataLoader
from PIL import Image


class AnimalReIDDataset(Dataset):
    def __init__(self, df, transform=None):
        self.df = df
        self.transform = transform
        self.base_path = Path("/kaggle/input/datasets/elliotmonde/cropped-animal-reid/processed_images/images")

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        row = self.df.iloc[idx]
        img_path = self.base_path / f"{row['image_id']}.jpg"
        image = Image.open(img_path).convert("RGB")

        if self.transform:
            image = self.transform(image)

        return image, torch.tensor(row["label"], dtype=torch.long)



from torch.utils.data import DataLoader
from torchvision import transforms
# 1. Define the BioCLIP-specific normalization
# These constants are critical for the pre-trained weights to work
bioclip_transforms = transforms.Compose(
    [
        transforms.Resize((224, 224)),
        transforms.RandomHorizontalFlip(p=0.5),  # Augmentation for ReID
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.481, 0.457, 0.408], std=[0.268, 0.261, 0.275]),
    ]
)

# 1. Prepare the DataFrame properly
df = get_meta_df()
train_df = df[df["split"] == "train"].copy()

# 2. Encode the identities into the 'label' column
from sklearn.preprocessing import LabelEncoder

le = LabelEncoder()
train_df["label"] = le.fit_transform(train_df["identity"])

# 3. CRITICAL: Pass THIS train_df to the dataset
# If you created 'train_dataset' BEFORE running the lines above, re-instantiate it:
train_dataset = AnimalReIDDataset(train_df, transform=bioclip_transforms)

# 4. Re-create the loader to be safe
train_loader = DataLoader(train_dataset, batch_size=4, shuffle=True, num_workers=0)


get_ipython().getoutput("PYTORCH_ALLOC_CONF=expandable_segments:True")


import torch
import torch.nn as nn

device = (
    1
    if torch.cuda.is_available()
    else "mps" if torch.backends.mps.is_available() else "cpu"
)

# Instantiate the model (it will auto-calculate num_identities)
model = BioCLIPReID().to(device)

# Use Differential Learning Rates
optimizer = torch.optim.AdamW(
    [
        {"params": model.backbone.parameters(), "lr": 1e-6},  # Very slow for backbone
        {"params": model.mhsa.parameters(), "lr": 1e-4},  # Normal for your neck
        {"params": model.bottleneck.parameters(), "lr": 1e-4},
        {"params": model.head.parameters(), "lr": 1e-4},
    ],
    weight_decay=0.01,
)

criterion = nn.CrossEntropyLoss(label_smoothing=0.1)



def train_one_epoch(model, dataloader, optimizer, criterion, device):
    # 1. SET TO TRAIN MODE
    # This activates Dropout and BatchNorm layers
    model.train()

    running_loss = 0.0

    # 2. THE DATA LOOP
    for images, labels in dataloader:
        images, labels = images.to(device), labels.to(device)

        # 3. ZERO THE GRADIENTS
        # Prevents gradients from accumulating from the previous batch
        optimizer.zero_grad()

        # 4. FORWARD PASS
        # Images go in -> Predicted Identity Logits come out
        outputs = model(images)

        # 5. CALCULATE LOSS
        # How far off was the model from the ground truth?
        loss = criterion(outputs, labels)

        # 6. BACKWARD PASS (The "Learning" Step)
        # Calculate how much each weight contributed to the error
        loss.backward()

        # 7. UPDATE WEIGHTS
        # The optimizer nudges the weights in the right direction
        optimizer.step()

        running_loss += loss.item()

    # Return the average loss for this entire epoch
    return running_loss / len(dataloader)


for epoch in range(20):
    loss = train_one_epoch(model, train_loader, optimizer, criterion, device)
    print(f"Epoch [{epoch+1}/20], Loss: {loss:.4f}")

    # Save a checkpoint every 5 epochs just in case
    if (epoch + 1) % 5 == 0:
        torch.save(model.state_dict(), f"bioclip_reid_epoch_{epoch+1}.pt")


